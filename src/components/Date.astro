---
interface Props {
  date: Date;
  currentLang: "en" | "es";
}

const { date, currentLang } = Astro.props;
const locale = currentLang === "es" ? "es-CL" : "en-US";
---

<time datetime={date.toISOString()}>
  {date.toLocaleDateString(locale, {
    year: "numeric",
    month: "short",
    day: "numeric",
  })}
</time>
